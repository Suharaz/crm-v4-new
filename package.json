{
  "name": "crm-v4",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:push": "pnpm --filter @crm/database db:push",
    "db:migrate": "pnpm --filter @crm/database db:migrate",
    "db:seed": "pnpm --filter @crm/database db:seed",
    "db:studio": "pnpm --filter @crm/database db:studio",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "turbo": "^2.8.20",
    "typescript-eslint": "^8.57.2"
  }
}
