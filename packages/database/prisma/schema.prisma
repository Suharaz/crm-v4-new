generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  MANAGER
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  POOL
  ASSIGNED
  IN_PROGRESS
  CONVERTED
  LOST
  FLOATING
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  FLOATING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum VerifiedSource {
  AUTO
  MANUAL
}

enum CallType {
  OUTGOING
  INCOMING
  MISSED
}

enum MatchStatus {
  AUTO_MATCHED
  UNMATCHED
  MANUALLY_MATCHED
}

enum EntityType {
  LEAD
  CUSTOMER
}

enum ActivityType {
  NOTE
  CALL
  STATUS_CHANGE
  ASSIGNMENT
  LABEL_CHANGE
  SYSTEM
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

// ─── USER & ORGANIZATION ────────────────────────────────────────────────────

model User {
  id               BigInt     @id @default(autoincrement())
  email            String
  passwordHash     String     @map("password_hash")
  phone            String?
  name             String
  role             UserRole   @default(USER)
  departmentId     BigInt?    @map("department_id")
  teamId           BigInt?    @map("team_id")
  employeeLevelId  BigInt?    @map("employee_level_id")
  isLeader         Boolean    @default(false) @map("is_leader")
  status           UserStatus @default(ACTIVE)
  failedLoginCount Int        @default(0) @map("failed_login_count")
  lockedUntil      DateTime?  @map("locked_until")
  metadata         Json?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  department    Department?    @relation(fields: [departmentId], references: [id])
  team          Team?          @relation("TeamMembers", fields: [teamId], references: [id])
  employeeLevel EmployeeLevel? @relation(fields: [employeeLevelId], references: [id])
  leadingTeam   Team?          @relation("TeamLeader")
  managedDepts  ManagerDepartment[] @relation("ManagedDepartments")

  // Leads & Customers assigned to user
  assignedLeads     Lead[]     @relation("LeadAssignedUser")
  assignedCustomers Customer[] @relation("CustomerAssignedUser")

  // Activities, orders, etc. created by user
  activities        Activity[]
  ordersCreated     Order[]    @relation("OrderCreator")
  paymentsVerified  Payment[]  @relation("PaymentVerifier")
  documentsUploaded Document[]

  // Assignment history
  assignmentsFrom   AssignmentHistory[] @relation("AssignmentFromUser")
  assignmentsTo     AssignmentHistory[] @relation("AssignmentToUser")
  assignmentsMade   AssignmentHistory[] @relation("AssignmentByUser")

  // Auth
  refreshTokens RefreshToken[]

  // Config & templates
  assignmentTemplatesCreated AssignmentTemplate[]
  recallConfigsCreated       RecallConfig[]
  apiKeysCreated             ApiKey[]

  // Tasks
  tasksAssigned Task[] @relation("TaskAssignee")
  tasksCreated  Task[] @relation("TaskCreator")

  // Notifications
  notifications Notification[]

  // Template membership
  templateMemberships AssignmentTemplateMember[]

  @@unique([email, deletedAt])
  @@index([departmentId])
  @@index([teamId])
  @@index([role, status])
  @@map("users")
}

model Department {
  id        BigInt    @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users    User[]
  teams    Team[]
  managers ManagerDepartment[]

  leads     Lead[]
  customers Customer[]

  assignmentsFromDept AssignmentHistory[] @relation("AssignmentFromDept")
  assignmentsToDept   AssignmentHistory[] @relation("AssignmentToDept")

  aiDistributionConfig AiDistributionConfig?

  @@map("departments")
}

model EmployeeLevel {
  id        BigInt    @id @default(autoincrement())
  name      String
  rank      Int
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users User[]

  @@map("employee_levels")
}

model Team {
  id           BigInt    @id @default(autoincrement())
  name         String
  departmentId BigInt    @map("department_id")
  leaderId     BigInt    @unique @map("leader_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  department Department @relation(fields: [departmentId], references: [id])
  leader     User       @relation("TeamLeader", fields: [leaderId], references: [id])
  members    User[]     @relation("TeamMembers")

  @@index([departmentId])
  @@map("teams")
}

model ManagerDepartment {
  managerId    BigInt   @map("manager_id")
  departmentId BigInt   @map("department_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  manager    User       @relation("ManagedDepartments", fields: [managerId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@id([managerId, departmentId])
  @@index([departmentId])
  @@map("manager_departments")
}

// ─── LEAD & CUSTOMER ────────────────────────────────────────────────────────

model Customer {
  id                   BigInt         @id @default(autoincrement())
  phone                String
  name                 String
  email                String?
  assignedUserId       BigInt?        @map("assigned_user_id")
  assignedDepartmentId BigInt?        @map("assigned_department_id")
  status               CustomerStatus @default(ACTIVE)
  metadata             Json?
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")

  assignedUser       User?       @relation("CustomerAssignedUser", fields: [assignedUserId], references: [id])
  assignedDepartment Department? @relation(fields: [assignedDepartmentId], references: [id])

  leads  Lead[]
  orders Order[]
  labels CustomerLabel[]

  @@index([assignedUserId])
  @@index([assignedDepartmentId, assignedUserId])
  @@map("customers")
}

model Lead {
  id               BigInt     @id @default(autoincrement())
  phone            String
  name             String
  email            String?
  customerId       BigInt?    @map("customer_id")
  productId        BigInt?    @map("product_id")
  sourceId         BigInt?    @map("source_id")
  assignedUserId   BigInt?    @map("assigned_user_id")
  departmentId     BigInt?    @map("department_id")
  status           LeadStatus @default(POOL)
  metadata         Json?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  customer     Customer?  @relation(fields: [customerId], references: [id])
  product      Product?   @relation(fields: [productId], references: [id])
  source       LeadSource? @relation(fields: [sourceId], references: [id])
  assignedUser User?      @relation("LeadAssignedUser", fields: [assignedUserId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])

  orders Order[]
  labels LeadLabel[]

  @@index([customerId])
  @@index([sourceId])
  @@index([productId])
  @@index([status, assignedUserId])
  @@index([departmentId])
  @@map("leads")
}

model LeadSource {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  leads Lead[]

  @@map("lead_sources")
}

// ─── PRODUCT, ORDER, PAYMENT ────────────────────────────────────────────────

model ProductCategory {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("product_categories")
}

model Product {
  id          BigInt    @id @default(autoincrement())
  name        String
  price       Decimal   @db.Decimal(12, 2)
  description String?
  categoryId  BigInt?   @map("category_id")
  vatRate     Decimal   @default(0) @map("vat_rate") @db.Decimal(5, 2)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  leads    Lead[]
  orders   Order[]

  @@index([categoryId])
  @@map("products")
}

model Order {
  id          BigInt      @id @default(autoincrement())
  leadId      BigInt?     @map("lead_id")
  customerId  BigInt      @map("customer_id")
  productId   BigInt?     @map("product_id")
  amount      Decimal     @db.Decimal(12, 2)
  vatRate     Decimal     @map("vat_rate") @db.Decimal(5, 2)
  vatAmount   Decimal     @map("vat_amount") @db.Decimal(12, 2)
  totalAmount Decimal     @map("total_amount") @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)
  notes       String?
  createdBy   BigInt      @map("created_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  lead     Lead?    @relation(fields: [leadId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  product  Product? @relation(fields: [productId], references: [id])
  creator  User     @relation("OrderCreator", fields: [createdBy], references: [id])

  payments Payment[]

  @@index([leadId])
  @@index([customerId])
  @@index([createdBy])
  @@map("orders")
}

model Payment {
  id                       BigInt         @id @default(autoincrement())
  orderId                  BigInt         @map("order_id")
  paymentTypeId            BigInt?        @map("payment_type_id")
  amount                   Decimal        @db.Decimal(12, 2)
  status                   PaymentStatus  @default(PENDING)
  transferContent          String?        @map("transfer_content")
  verifiedSource           VerifiedSource? @map("verified_source")
  verifiedBy               BigInt?        @map("verified_by")
  verifiedAt               DateTime?      @map("verified_at")
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")

  order               Order            @relation(fields: [orderId], references: [id])
  paymentType         PaymentType?     @relation(fields: [paymentTypeId], references: [id])
  verifier            User?            @relation("PaymentVerifier", fields: [verifiedBy], references: [id])
  matchedTransaction  BankTransaction?

  @@index([orderId])
  @@map("payments")
}

model PaymentType {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  payments Payment[]

  @@map("payment_types")
}

model BankTransaction {
  id               BigInt      @id @default(autoincrement())
  externalId       String      @unique @map("external_id")
  amount           Decimal     @db.Decimal(12, 2)
  content          String
  bankAccount      String?     @map("bank_account")
  senderName       String?     @map("sender_name")
  senderAccount    String?     @map("sender_account")
  transactionTime  DateTime    @map("transaction_time")
  matchedPaymentId BigInt?     @unique @map("matched_payment_id")
  matchStatus      MatchStatus @default(UNMATCHED) @map("match_status")
  rawData          Json?       @map("raw_data")
  createdAt        DateTime    @default(now()) @map("created_at")

  matchedPayment Payment? @relation(fields: [matchedPaymentId], references: [id])

  @@index([matchStatus, createdAt])
  @@index([amount, transactionTime])
  @@map("bank_transactions")
}

// ─── LABELS ─────────────────────────────────────────────────────────────────

model Label {
  id        BigInt   @id @default(autoincrement())
  name      String
  color     String   @default("#6b7280")
  category  String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leadLabels     LeadLabel[]
  customerLabels CustomerLabel[]

  @@map("labels")
}

model LeadLabel {
  leadId    BigInt   @map("lead_id")
  labelId   BigInt   @map("label_id")
  createdAt DateTime @default(now()) @map("created_at")

  lead  Lead  @relation(fields: [leadId], references: [id])
  label Label @relation(fields: [labelId], references: [id])

  @@id([leadId, labelId])
  @@index([labelId])
  @@map("lead_labels")
}

model CustomerLabel {
  customerId BigInt   @map("customer_id")
  labelId    BigInt   @map("label_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])
  label    Label    @relation(fields: [labelId], references: [id])

  @@id([customerId, labelId])
  @@index([labelId])
  @@map("customer_labels")
}

// ─── ACTIVITY & DOCUMENTS ───────────────────────────────────────────────────

model Activity {
  id         BigInt       @id @default(autoincrement())
  entityType EntityType   @map("entity_type")
  entityId   BigInt       @map("entity_id")
  userId     BigInt       @map("user_id")
  type       ActivityType
  content    String?
  metadata   Json?
  createdAt  DateTime     @default(now()) @map("created_at")
  deletedAt  DateTime?    @map("deleted_at")

  user        User                 @relation(fields: [userId], references: [id])
  attachments ActivityAttachment[]

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
  @@map("activities")
}

model ActivityAttachment {
  id         BigInt   @id @default(autoincrement())
  activityId BigInt   @map("activity_id")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  fileType   String   @map("file_type")
  fileSize   Int      @map("file_size")
  createdAt  DateTime @default(now()) @map("created_at")

  activity Activity @relation(fields: [activityId], references: [id])

  @@index([activityId])
  @@map("activity_attachments")
}

model Document {
  id          BigInt     @id @default(autoincrement())
  entityType  EntityType @map("entity_type")
  entityId    BigInt     @map("entity_id")
  uploadedBy  BigInt     @map("uploaded_by")
  fileName    String     @map("file_name")
  fileUrl     String     @map("file_url")
  fileType    String     @map("file_type")
  fileSize    Int        @map("file_size")
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  deletedAt   DateTime?  @map("deleted_at")

  uploader User @relation(fields: [uploadedBy], references: [id])

  @@index([entityType, entityId, createdAt])
  @@map("documents")
}

// ─── CALL LOGS ──────────────────────────────────────────────────────────────

model CallLog {
  id                BigInt      @id @default(autoincrement())
  externalId        String      @unique @map("external_id")
  phoneNumber       String      @map("phone_number")
  callType          CallType    @map("call_type")
  callTime          DateTime    @map("call_time")
  duration          Int         @default(0)
  content           String?
  matchedEntityType EntityType? @map("matched_entity_type")
  matchedEntityId   BigInt?     @map("matched_entity_id")
  matchedUserId     BigInt?     @map("matched_user_id")
  matchStatus       MatchStatus @default(UNMATCHED) @map("match_status")
  verifiedBy        BigInt?     @map("verified_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  deletedAt         DateTime?   @map("deleted_at")

  @@index([phoneNumber, callTime])
  @@index([matchedEntityType, matchedEntityId, callTime])
  @@map("call_logs")
}

// ─── ASSIGNMENT ─────────────────────────────────────────────────────────────

model AssignmentHistory {
  id               BigInt     @id @default(autoincrement())
  entityType       EntityType @map("entity_type")
  entityId         BigInt     @map("entity_id")
  fromUserId       BigInt?    @map("from_user_id")
  toUserId         BigInt?    @map("to_user_id")
  fromDepartmentId BigInt?    @map("from_department_id")
  toDepartmentId   BigInt?    @map("to_department_id")
  assignedBy       BigInt     @map("assigned_by")
  reason           String?
  createdAt        DateTime   @default(now()) @map("created_at")

  fromUser       User?       @relation("AssignmentFromUser", fields: [fromUserId], references: [id])
  toUser         User?       @relation("AssignmentToUser", fields: [toUserId], references: [id])
  assignedByUser User        @relation("AssignmentByUser", fields: [assignedBy], references: [id])
  fromDepartment Department? @relation("AssignmentFromDept", fields: [fromDepartmentId], references: [id])
  toDepartment   Department? @relation("AssignmentToDept", fields: [toDepartmentId], references: [id])

  @@index([entityType, entityId, createdAt])
  @@map("assignment_history")
}

model AssignmentTemplate {
  id        BigInt   @id @default(autoincrement())
  name      String
  strategy  String   @default("ROUND_ROBIN")
  isActive  Boolean  @default(true) @map("is_active")
  createdBy BigInt   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator User                     @relation(fields: [createdBy], references: [id])
  members AssignmentTemplateMember[]

  @@map("assignment_templates")
}

model AssignmentTemplateMember {
  templateId BigInt @map("template_id")
  userId     BigInt @map("user_id")

  template AssignmentTemplate @relation(fields: [templateId], references: [id])
  user     User               @relation(fields: [userId], references: [id])

  @@id([templateId, userId])
  @@map("assignment_template_members")
}

// ─── AI DISTRIBUTION ────────────────────────────────────────────────────────

model AiDistributionConfig {
  id               BigInt   @id @default(autoincrement())
  departmentId     BigInt   @unique @map("department_id")
  isActive         Boolean  @default(true) @map("is_active")
  matchingCriteria Json?    @map("matching_criteria")
  weightConfig     Json?    @map("weight_config")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id])

  @@map("ai_distribution_configs")
}

// ─── RECALL CONFIG ──────────────────────────────────────────────────────────

model RecallConfig {
  id            BigInt   @id @default(autoincrement())
  entityType    String   @map("entity_type")
  maxDaysInPool Int      @map("max_days_in_pool")
  autoLabelIds  BigInt[] @map("auto_label_ids")
  isActive      Boolean  @default(true) @map("is_active")
  createdBy     BigInt   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  creator User @relation(fields: [createdBy], references: [id])

  @@map("recall_configs")
}

// ─── TASKS / TODO ───────────────────────────────────────────────────────────

model Task {
  id            BigInt       @id @default(autoincrement())
  title         String
  description   String?
  entityType    EntityType?  @map("entity_type")
  entityId      BigInt?      @map("entity_id")
  assignedTo    BigInt       @map("assigned_to")
  createdBy     BigInt       @map("created_by")
  dueDate       DateTime?    @map("due_date")
  remindAt      DateTime?    @map("remind_at")
  remindedAt    DateTime?    @map("reminded_at")
  escalation1At DateTime?    @map("escalation_1_at")
  escalation2At DateTime?    @map("escalation_2_at")
  status        TaskStatus   @default(PENDING)
  priority      TaskPriority @default(MEDIUM)
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  assignee User @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator  User @relation("TaskCreator", fields: [createdBy], references: [id])

  @@index([assignedTo, status, dueDate])
  @@index([remindAt, remindedAt, status])
  @@map("tasks")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  tokenHash String    @map("token_hash")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id          BigInt    @id @default(autoincrement())
  name        String
  keyHash     String    @unique @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  permissions String[]  @default(["leads:create"])
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  createdBy   BigInt    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  expiresAt   DateTime? @map("expires_at")

  creator User @relation(fields: [createdBy], references: [id])

  @@map("api_keys")
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────────────────

model Notification {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  title     String
  content   String?
  type      String    @default("SYSTEM")
  entityType EntityType? @map("entity_type")
  entityId  BigInt?   @map("entity_id")
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
