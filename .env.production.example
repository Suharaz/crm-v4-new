# Database (Docker)
DB_USER=crm
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=crm_v4
DB_PORT=5433
# connection_limit: default = num_cpus*2+1 (5 on 2-core). Set 20 for 200 concurrent users.
# pool_timeout: seconds to wait for a connection before error (default 10).
DATABASE_URL=postgresql://crm:CHANGE_ME_strong_password@localhost:5433/crm_v4?connection_limit=20&pool_timeout=10

# Redis (Docker)
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_PORT=6380
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6380

# Auth (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_random_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_another_random_32_chars

# Seed password (REQUIRED in production for pnpm db:seed)
# Generate with: openssl rand -base64 16
SEED_PASSWORD=CHANGE_ME_min_8_chars

# Node env — CRITICAL for seed fail-fast guard
NODE_ENV=production

# URLs (replace with your domain)
API_PORT=3010
FRONTEND_URL=https://crm.yourdomain.com
# IMPORTANT: NEXT_PUBLIC_API_URL phải là HTTPS public URL, không phải localhost
# Vì Next.js inject biến này vào client bundle → browser user gọi trực tiếp
NEXT_PUBLIC_API_URL=https://crm.yourdomain.com/api/v1

# Webhook security (generate with: openssl rand -hex 32)
# Required for HMAC-SHA256 signature verification on bank webhooks
WEBHOOK_SECRET=CHANGE_ME_webhook_secret

# Storage
UPLOAD_DIR=./uploads
