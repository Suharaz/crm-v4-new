# Database (connection_limit=Prisma pool size, pool_timeout=seconds to wait)
DATABASE_URL=postgresql://crm:crm@localhost:5433/crm_v4?connection_limit=20&pool_timeout=10

# Auth
JWT_SECRET=change-me-to-random-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-32-chars

# Webhook signature (HMAC-SHA256 over raw body). Required by WebhookSignatureGuard.
# Dev value below is non-secret - production phải dùng `openssl rand -hex 32`
WEBHOOK_SECRET=dev-webhook-secret-32-chars-minimum-len-1234

# Server
API_PORT=3010
FRONTEND_URL=http://localhost:3011
NEXT_PUBLIC_API_URL=http://localhost:3010/api/v1

# Storage
UPLOAD_DIR=./uploads
REDIS_URL=redis://localhost:6380
