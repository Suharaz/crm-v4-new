# Ép LF cho shell scripts + config (tránh CRLF khi clone từ Windows → Linux VPS)
*.sh text eol=lf
*.bash text eol=lf

# Dockerfile, compose, env files — Unix only
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
.env* text eol=lf

# YAML (GitHub Actions, Docker Compose) — LF
*.yml text eol=lf
*.yaml text eol=lf

# Các loại text khác: auto normalize
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.md text

# Binary files — không convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
